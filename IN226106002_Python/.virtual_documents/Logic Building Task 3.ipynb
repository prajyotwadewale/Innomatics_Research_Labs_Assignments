#Problem Statement 1: Employee Performance Bonus Eligibility

employees = {
    "Ravi": 92,
    "Anita": 88,
    "Kiran": 92,
    "Suresh": 85
}

highest_score = max(employees.values())
top_performers = []  #highest score

for name, score in employees.items():
    if score == highest_score:
        top_performers.append(name)
        
print("Top Performers Eligible for Bonus:", 
      ", ".join(top_performers), 
      f"(Score: {highest_score})")





#Problem Statement 2: Search Query Keyword Analysis

import string

query = "Buy mobile phone buy phone online"
query = query.lower()  #Convert to lowercase

#Remove punctuation
query = query.translate(str.maketrans('', '', string.punctuation))

words = query.split()
frequency = {}

for word in words:
    if word in frequency:
        frequency[word] += 1
    else:
        frequency[word] = 1

result = {}

for word, count in frequency.items():
    if count > 1:
        result[word] = count

print(result)





#Problem Statement 3: Sensor Data Validation

sensor_readings = [3, 4, 7, 8, 10, 12, 5]

valid_readings = []

# Loop through list using index and value
for index, value in enumerate(sensor_readings):
    if value % 2 == 0:   # Check if even
        valid_readings.append((index, value))

print("Valid Sensor Readings (Hour, Value):")
print(valid_readings)





#Problem Statement 4: Email Domain Usage Analysis

emails = [
    "ravi@gmail.com",
    "anita@yahoo.com",
    "kiran@gmail.com",
    "suresh@gmail.com",
    "meena@yahoo.com"
]

domain_count = {}

for email in emails:
    domain = email.split("@")[1]   # Extract domain
    
    if domain in domain_count:
        domain_count[domain] += 1
    else:
        domain_count[domain] = 1

# Calculate percentage
total_users = len(emails)

print("Email Domain Usage:")
for domain, count in domain_count.items():
    percentage = (count / total_users) * 100
    print(f"{domain}: {int(percentage)}%")





#Problem Statement 5: Sales Spike Detection

sales = [1200, 1500, 900, 2200, 1400, 3000]

#Calculate average sales
average_sales = sum(sales) / len(sales)

#Define spike threshold (30% above average)
threshold = average_sales * 1.30

#Detect spike days
for index, value in enumerate(sales):
    if value > threshold:
        print(f"Day {index + 1}: {value}")





#Problem Statement 6: Duplicate User ID Detection

user_ids = ["user1", "user2", "user1", "user3", "user1", "user3"]

id_count = {}

for user in user_ids:
    if user in id_count:
        id_count[user] += 1
    else:
        id_count[user] = 1

#Display only duplicates
for user, count in id_count.items():
    if count > 1:
        print(f"{user} → {count} times")



